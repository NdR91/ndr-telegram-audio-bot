# Telegram token (required)
TELEGRAM_TOKEN=your_telegram_bot_token

# --- OpenAI provider (default) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
# Optional: override model name (default: gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini

# --- Google Gemini provider (alternative) ---
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key
# LLM_MODEL=gemini-1.5-flash
# Or preview/experimental models:
# LLM_MODEL=gemini-2.0-flash-exp

# --- Prompt configuration (optional) ---
# PROMPT_SYSTEM="You are an audio transcription expert. Correct automatic errors, add punctuation, maintain original meaning, and return ONLY the corrected text without comments."
# PROMPT_REFINE_TEMPLATE="This is text generated by automatic transcription... {raw_text} ..."

# --- Rate Limiting ---
# Max concurrent audio processing requests per user (default=2)
RATE_LIMIT_PER_USER=2
# Cooldown in seconds after hitting user limit (default=30)
RATE_LIMIT_COOLDOWN=30
# Max global concurrent requests for the bot (default=6)
RATE_LIMIT_GLOBAL=6
# Max file size in MB (Telegram Bot API limit is 20MB) (default=20)
RATE_LIMIT_FILE_SIZE=20
# Queue requests when all global slots are busy (default=1)
RATE_LIMIT_QUEUE_ENABLED=1
# Max queued requests across all users (default=10)
RATE_LIMIT_QUEUE_SIZE=10
# Max queued requests per user (default=1)
RATE_LIMIT_QUEUE_PER_USER=1

# Persistent whitelist database (default: audio_files/authorized.sqlite3)
AUTHORIZED_DB=audio_files/authorized.sqlite3

# Provider resilience / circuit breaker
PROVIDER_RESILIENCE_ENABLED=1
PROVIDER_RESILIENCE_THRESHOLD=3
PROVIDER_RESILIENCE_COOLDOWN=60

# Telegram progressive output feature flag (default: 0/off)
# Current behavior: progressive final-text reveal in private chats when draft support is available.
# Fallback remains the classic edit/send flow for all unsupported cases.
TELEGRAM_DRAFT_STREAMING=0

# --- Audio temp cleanup (optional) ---
# Cleanup temp files in AUDIO_DIR on startup (default=1)
# Set to 0 to disable
AUDIO_CLEANUP_ON_STARTUP=1

# --- Logging (optional) ---
# By default, transcript/refined text content is hidden in logs and only metadata is logged.
# Set to 1 only for short-lived debugging sessions because full transcribed/refined text
# may contain sensitive user content and will be written to DEBUG logs.
LOG_SENSITIVE_TEXT=0
